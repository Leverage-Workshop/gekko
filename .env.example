# Supabase (feat-005)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Ingest bearer token (feat-008) — shared secret the local uploader presents as
# `Authorization: Bearer <token>` to POST /api/ingest. Generate a long random
# value (e.g. `openssl rand -hex 32`) and set the same value on the uploader.
INGEST_BEARER_TOKEN=

# Local uploader (feat-009) — runs on the Windows trading machine. Polls
# GET /api/ingest every UPLOADER_POLL_MS asking whether a fresh bundle is
# required (a dashboard run button was pressed), and only then bundles the
# Sierra Chart export folder and POSTs it. Reuses INGEST_BEARER_TOKEN (above)
# as the bearer credential.
#   INGEST_URL: full URL of the deployed (or local) ingest endpoint.
#   GEKKO_EXPORT_DIR: folder Sierra Chart exports into (e.g. C:\gekko\export).
# The UPLOADER_* knobs are optional (defaults shown). UPLOADER_DEBOUNCE_MS is
# the settle window: an upload is deferred to the next poll while any export
# file changed within it (Sierra mid-rewrite).
INGEST_URL=
GEKKO_EXPORT_DIR=
UPLOADER_POLL_MS=7000
UPLOADER_DEBOUNCE_MS=1000
UPLOADER_MAX_ATTEMPTS=5
UPLOADER_BASE_DELAY_MS=500
UPLOADER_MAX_DELAY_MS=30000

# trigger.dev (feat-010/feat-020) — background workflow runner.
# Setup, local `trigger.dev dev`, and `trigger.dev deploy` all use the
# trigger.dev CLI login (token stored under ~/.config/trigger), so NO env var
# is required for the project setup itself. TRIGGER_SECRET_KEY is REQUIRED at
# app runtime since feat-020: POST /api/briefings/run calls tasks.trigger()
# server-side. Grab the per-environment secret key from the trigger.dev
# dashboard (Project → API keys): tr_dev_* while running `trigger.dev dev`,
# tr_prod_* against the deployed worker.
TRIGGER_SECRET_KEY=

# OpenRouter — LLM gateway for the Vercel AI SDK (feat-007).
# The model id is NOT set here; it is read from the `config` row
# (default anthropic/claude-sonnet-4-6). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# LangSmith LLM telemetry (feat-030) — OPTIONAL. When LANGSMITH_API_KEY is set,
# every analyze/eval LLM call is traced to LangSmith via their official Vercel
# AI SDK integration (wrapAISDK): call inputs + JSON response, chart images
# redacted. Unset = telemetry fully disabled; nothing else changes — the
# standard LANGSMITH_TRACING flag is NOT required (the key alone is the
# switch). Set these on the trigger.dev environment (the tasks make the LLM
# calls, not the Next.js app).
#   LANGSMITH_API_KEY:      key from https://smith.langchain.com (Settings → API Keys)
#   LANGSMITH_PROJECT:      optional LangSmith project name to file traces under
#   LANGSMITH_ENDPOINT:     optional API base URL override
#                           (default https://api.smith.langchain.com;
#                           EU: https://eu.api.smith.langchain.com)
#   LANGSMITH_WORKSPACE_ID: only needed if the key spans multiple workspaces
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
# LANGSMITH_ENDPOINT=
# LANGSMITH_WORKSPACE_ID=

# Web Push / VAPID (feat-027) — OPTIONAL. Enables alerts when the tab is
# fully closed; unset = push is a silent no-op (tab-open Realtime
# notifications, feat-026, still work). Generate a keypair ONCE with:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY get the SAME public key
# (the NEXT_PUBLIC_ copy is inlined into the browser bundle for
# pushManager.subscribe); the private key stays server-side — never commit
# it. The analyze/eval tasks do the sending, so set VAPID_PUBLIC_KEY,
# VAPID_PRIVATE_KEY, and VAPID_SUBJECT on the trigger.dev environment too.
# VAPID_SUBJECT is a mailto: or https: contact for push services
# (defaults to mailto:gekko@localhost when unset).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
