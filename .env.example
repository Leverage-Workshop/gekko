# Supabase (feat-005)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Ingest bearer token (feat-008) — shared secret the local uploader presents as
# `Authorization: Bearer <token>` to POST /api/ingest. Generate a long random
# value (e.g. `openssl rand -hex 32`) and set the same value on the uploader.
INGEST_BEARER_TOKEN=

# OpenRouter — LLM gateway for the Vercel AI SDK (feat-007).
# The model id is NOT set here; it is read from the `config` row
# (default anthropic/claude-sonnet-4-6). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
