# Supabase (feat-005)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Ingest bearer token (feat-008) — shared secret the local uploader presents as
# `Authorization: Bearer <token>` to POST /api/ingest. Generate a long random
# value (e.g. `openssl rand -hex 32`) and set the same value on the uploader.
INGEST_BEARER_TOKEN=

# Local uploader (feat-009) — runs on the Windows trading machine, watching the
# Sierra Chart export folder and POSTing bundles to /api/ingest. Reuses
# INGEST_BEARER_TOKEN (above) as the bearer credential.
#   INGEST_URL: full URL of the deployed (or local) ingest endpoint.
#   GEKKO_EXPORT_DIR: folder Sierra Chart exports into (e.g. C:\gekko\export).
# The UPLOADER_* knobs are optional (defaults shown).
INGEST_URL=
GEKKO_EXPORT_DIR=
UPLOADER_DEBOUNCE_MS=2000
UPLOADER_MAX_ATTEMPTS=5
UPLOADER_BASE_DELAY_MS=500
UPLOADER_MAX_DELAY_MS=30000

# OpenRouter — LLM gateway for the Vercel AI SDK (feat-007).
# The model id is NOT set here; it is read from the `config` row
# (default anthropic/claude-sonnet-4-6). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
